---
import { getPosters, type PosterRecord, type HeroTemplateRecord } from "../lib/db";
import interacLogo from "../assets/Interac.Logo1.png";
import PostersCarousel from "./PostersCarousel.astro";

interface Props {
  heroTemplate?: HeroTemplateRecord | null;
}

// Function to convert video URLs to embeddable format
function getEmbedUrl(url: string): string {
  if (!url) return '';
  
  // YouTube - convert watch URLs to embed format
  if (url.includes('youtube.com') || url.includes('youtu.be')) {
    // Handle youtube.com/watch?v=ID format
    const watchMatch = url.match(/[?&]v=([^&]+)/);
    if (watchMatch) {
      const videoId = watchMatch[1];
      return `https://www.youtube.com/embed/${videoId}?autoplay=1&muted=1&controls=0&modestbranding=1&enablejsapi=1`;
    }
    
    // Handle youtu.be/ID format
    const shortMatch = url.match(/youtu\.be\/([^?&]+)/);
    if (shortMatch) {
      const videoId = shortMatch[1];
      return `https://www.youtube.com/embed/${videoId}?autoplay=1&muted=1&controls=0&modestbranding=1&enablejsapi=1`;
    }
    
    // Already embed format
    if (url.includes('/embed/')) {
      const baseUrl = url.split('?')[0];
      return `${baseUrl}?autoplay=1&muted=1&controls=0&modestbranding=1&enablejsapi=1`;
    }
  }
  
  // Streamable - ensure it's in embed format with autoplay
  if (url.includes('streamable.com')) {
    if (url.includes('/e/')) {
      return url.includes('?') ? url : `${url}?autoplay=1&muted=1`;
    }
    // Convert watch URL to embed format
    const streamMatch = url.match(/streamable\.com\/([^/?]+)/);
    if (streamMatch) {
      const videoId = streamMatch[1];
      return `https://streamable.com/e/${videoId}?autoplay=1&muted=1`;
    }
  }
  
  // Return URL as-is if no conversion needed
  return url.includes('?') ? url : `${url}?autoplay=1&muted=1`;
}

// Extract video type from URL
function getVideoType(url: string): 'youtube' | 'streamable' | 'other' {
  if (url.includes('youtube.com') || url.includes('youtu.be')) return 'youtube';
  if (url.includes('streamable.com')) return 'streamable';
  return 'other';
}

const { heroTemplate } = Astro.props;

const posters: Array<PosterRecord> = await getPosters();
---

<div class="px-4 p-2 md:px-8 md:py-2 mx-auto">
  <div class="container mt-5">
    <!-- Web View -->
    <div class={heroTemplate?.fullWidth ? "block" : "block lg:flex lg:gap-5"}>
      <!-- LEFT (Hero) -->
      <div class={heroTemplate?.fullWidth ? "w-full mb-8" : "w-full mb-12 lg:mb-0 lg:w-[49%]"}>
        <!-- NEW CENTRE CARD -->
        <div
          class="relative bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100 group flex flex-col"
        >
          <!-- 
            TOP SECTION: Dark Background 
            Contains Badge and Title.
            Ends with an SVG Wave that transitions to white.
          -->
          <div 
            class="relative pt-10 px-8 md:px-10 pb-24 md:pb-32"
            style={heroTemplate 
              ? heroTemplate.backgroundType === 'color' 
                ? `background: ${heroTemplate.backgroundColor};`
                : `background-image: url('${heroTemplate.backgroundImageUrl}'); background-size: cover; background-position: center; background-attachment: fixed;`
              : 'background: linear-gradient(to bottom right, #8B2E0C, #C84C3C);'
            }
          >
            <!-- Content -->
            <div class="relative z-10">
              <!-- Badge -->
              <span
                class="inline-block px-4 py-1.5 rounded-full bg-white/20 text-white font-bold text-xs tracking-wider mb-6 backdrop-blur-sm border border-white/10 shadow-sm"
              >
                {heroTemplate?.badge || 'UPCOMING PROJECT'}
              </span>

              <!-- Heading -->
              <h2
                class="text-3xl md:text-5xl font-black text-white leading-tight drop-shadow-sm"
              >
                {heroTemplate?.title || 'New Omar Ibn Al Khattab Centre'}
              </h2>

              <!-- Subtitle (if provided) -->
              {heroTemplate?.subtitle && (
                <p class="text-lg text-white/90 leading-relaxed mt-4 drop-shadow-sm max-w-2xl">
                  {heroTemplate.subtitle}
                </p>
              )}
            </div>

            <!-- 
              SVG Shape Divider 
              Positioned absolute at the bottom.
              Fill matches the bottom section (Very Dark Terracotta).
            -->
            <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-[0]">
              <svg
                data-name="Layer 1"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 1200 120"
                preserveAspectRatio="none"
                class="relative block w-[calc(100%+1.3px)] h-[60px] md:h-[120px]"
                style="fill: #3d1a12;"
              >
                <!-- 
                  Gentle/Elegant Curve Path:
                  A single smooth asymmetric wave.
                  Starts high on left, dips gently, rises slightly on right.
                  Refined to be less "humpy".
                -->
                <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" class="hidden"></path>
                
                <!-- NEW SMOOTH PATH -->
                <path d="M0,60 C400,130 800,10 1200,50 V120 H0 Z" />
              </svg>
            </div>
          </div>

          <!-- 
            BOTTOM SECTION: Very Dark Terracotta Background 
            Contains Body, Video, CTA.
            The visual "top" of this section is actually the SVG wave above.
          -->
          <div class="relative px-8 md:px-10 pb-10 md:pb-12 pt-0 -mt-2" style="background-color: #3d1a12;">
            <!-- 
                Review Content 
            -->
             <p class="text-gray-300 text-lg leading-relaxed mb-8 font-medium">
              {heroTemplate 
                ? `${heroTemplate.title} - ${heroTemplate.ctaText}`
                : 'Introducing the new Omar bin-al-Khattab centre, a beacon of progress and possibility. This purpose-built facility will be more than just a building. It will be a hub of activity. A place where our children can learn and grow, where families can come together in prayer and fellowship and where the bonds of community are strengthened.'
              }
            </p>

            <!-- Video Wrapper with Custom Controls -->
            {(heroTemplate?.videoUrl || !heroTemplate) && (
              <div class="mb-8">
                <div
                  class="relative rounded-2xl overflow-hidden shadow-lg bg-gray-800 aspect-video ring-4 ring-terracottaRed-darker/30 group"
                  id="videoContainer"
                  data-video-type={heroTemplate?.videoUrl ? getVideoType(heroTemplate.videoUrl) : 'streamable'}
                >
                  <iframe
                    id="videoIframe"
                    allow="fullscreen;autoplay"
                    allowfullscreen
                    height="100%"
                    src={heroTemplate?.videoUrl 
                      ? getEmbedUrl(heroTemplate.videoUrl)
                      : 'https://streamable.com/e/cvo5ln?autoplay=1&muted=1'
                    }
                    width="100%"
                    class="absolute inset-0 w-full h-full border-0"></iframe>
                  
                  <!-- Custom Controls Overlay -->
                  <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 to-transparent p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-between">
                    <!-- Play/Pause Button -->
                    <button
                      id="playPauseBtn"
                      class="flex items-center justify-center w-10 h-10 rounded-full bg-white/20 hover:bg-white/40 transition-colors"
                      title="Play/Pause"
                      aria-label="Play or pause video"
                    >
                      <svg id="playIcon" class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z"></path>
                      </svg>
                      <svg id="pauseIcon" class="w-5 h-5 text-white hidden" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"></path>
                      </svg>
                    </button>

                    <!-- Mute/Unmute Button -->
                    <button
                      id="muteBtn"
                      class="flex items-center justify-center w-10 h-10 rounded-full bg-white/20 hover:bg-white/40 transition-colors"
                      title="Mute/Unmute"
                      aria-label="Mute or unmute video"
                    >
                      <svg id="volumeHighIcon" class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.26 2.5-4.02zM14 3.1v2.02c2.84.86 4.93 3.5 4.93 6.85s-2.09 5.99-4.93 6.85v2.02c4.45-.9 7.75-4.9 7.75-8.87 0-3.97-3.3-7.97-7.75-8.87z"></path>
                      </svg>
                      <svg id="volumeMuteIcon" class="w-5 h-5 text-white hidden" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M16.6 21.9L4.7 10H4c-1.1 0-2-.9-2-2v-6c0-1.1.9-2 2-2h.7L16.6 21.9zM19.7 21L21 19.7 12 10.7V4l-5 5H4c-1.1 0-2 .9-2 2v6c0 1.1.9 2 2 2h3l9 9 3-3zM19 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.05-.2.05-.42.05-.63z"></path>
                      </svg>
                    </button>
                  </div>
                </div>
              </div>
            )}

            <!-- Donation Encouragement (Only show if not using hero template) -->
            {!heroTemplate && (
              <div class="mb-6">
                <p
                  class="text-lg md:text-xl font-bold text-white leading-snug"
                >
                  Donate now and be a part of something truly transformative,
                  empowering our community, building our future.
                </p>
              </div>
            )}

            <!-- Action Area -->
            <div
              class="flex flex-col sm:flex-row gap-4 items-center justify-between border-t pt-6"
              style="border-color: rgba(139, 69, 19, 0.3);"
            >
              {heroTemplate ? (
                <a
                  href={heroTemplate.ctaLink}
                  class="w-full sm:w-auto px-8 py-3 bg-terracottaRed text-white rounded-xl font-bold shadow-md hover:shadow-xl hover:bg-terracottaRed-dark hover:-translate-y-0.5 transition-all text-center"
                >
                  {heroTemplate.ctaText}
                </a>
              ) : (
                <>
                  <a
                    href="/newcentre"
                    class="font-semibold text-white hover:text-terracottaRed transition-colors"
                    >View Construction Updates →</a
                  >

                  <a
                    href="/donatetonewcentre"
                    class="w-full sm:w-auto px-8 py-3 bg-terracottaRed text-white rounded-xl font-bold shadow-md hover:shadow-xl hover:bg-terracottaRed-dark hover:-translate-y-0.5 transition-all text-center"
                    >Donate Now</a
                  >
                </>
              )}
            </div>

            <!-- E-Transfer Donation Card (Only show if not using hero template) -->
            {!heroTemplate && (
              <div class="mt-6 border-2 border-white/20 rounded-xl p-4 md:p-5 bg-gradient-to-br from-terracottaRed-darker/30 to-terracottaRed/20 backdrop-blur-sm">
                <!-- Label -->
                <p class="text-white/90 text-sm md:text-base font-semibold mb-3 flex items-center gap-2">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                  Or donate via e-Transfer to:
                </p>

                <!-- Unified Card: Interac + Email + Copy Button -->
                <div class="bg-white/10 rounded-lg p-3 md:p-4 border border-white/20">
                  <div class="flex items-center gap-3 flex-wrap sm:flex-nowrap">
                    <!-- Interac Logo (Trust Badge) -->
                    <div class="flex-shrink-0">
                      <img
                        src={interacLogo.src}
                        alt="Interac e-Transfer"
                        class="h-7 md:h-8 lg:h-9 w-auto object-contain"
                      />
                    </div>

                    <!-- Email Address -->
                    <a
                      href="mailto:new.project@oiacedmonton.ca"
                      class="flex-1 min-w-0 text-white font-bold text-sm md:text-base lg:text-lg hover:text-warmWhite transition-colors break-words"
                      title="Click to email"
                    >
                      new.project@oiacedmonton.ca
                    </a>

                    <!-- Copy Button -->
                    <button
                      id="copyEmailBtn"
                      type="button"
                      class="flex-shrink-0 inline-flex items-center gap-2 px-3 py-2 md:px-4 md:py-2.5 bg-white/10 hover:bg-white/20 rounded-lg transition-all group border border-white/30 hover:border-white/50"
                      title="Copy email address"
                      aria-label="Copy email address to clipboard"
                    >
                      <svg class="w-4 h-4 md:w-5 md:h-5 text-white group-hover:text-warmWhite transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                      </svg>
                      <span class="text-white text-xs md:text-sm font-semibold hidden sm:inline">Copy</span>
                    </button>
                  </div>
                </div>

                <!-- Success Message -->
                <div id="copySuccess" class="hidden mt-2 text-sm text-green-300 font-medium flex items-center gap-1 animate-fade-in">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Email address copied!
                </div>
              </div>
            )}
          </div>
        </div>
      </div>

      <!-- RIGHT (Carousel) -->
      <div class={heroTemplate?.fullWidth ? "w-full" : "w-full lg:w-[49%] my-3"}>
        <PostersCarousel posters={posters} />
      </div>
    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyBtn = document.getElementById('copyEmailBtn');
    const successMsg = document.getElementById('copySuccess');
    const emailAddress = 'new.project@oiacedmonton.ca';

    if (copyBtn && successMsg) {
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(emailAddress);

          // Show success message
          successMsg.classList.remove('hidden');

          // Change button icon to checkmark temporarily
          const svg = copyBtn.querySelector('svg');
          const originalPath = svg?.innerHTML;
          if (svg) {
            svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>';
          }

          // Reset after 2 seconds
          setTimeout(() => {
            successMsg.classList.add('hidden');
            if (svg && originalPath) {
              svg.innerHTML = originalPath;
            }
          }, 2000);
        } catch (err) {
          console.error('Failed to copy email:', err);
          // Fallback: select the email text
          const emailLink = document.querySelector('a[href="mailto:new.project@oiacedmonton.ca"]');
          if (emailLink) {
            const range = document.createRange();
            range.selectNode(emailLink);
            window.getSelection()?.removeAllRanges();
            window.getSelection()?.addRange(range);
          }
        }
      });
    }

    // Video Control Functionality
    let youtubePlayer: any = null;
    let isPlaying = true; // Starts muted and autoplaying
    let isMuted = true;

    // Load YouTube API if YouTube video
    const videoContainer = document.getElementById('videoContainer');
    const videoType = videoContainer?.getAttribute('data-video-type');

    if (videoType === 'youtube') {
      // Load YouTube IFrame API
      const tag = document.createElement('script');
      tag.src = 'https://www.youtube.com/iframe_api';
      document.head.appendChild(tag);

      // Wait for API to load
      (window as any).onYouTubeIframeAPIReady = function() {
        const iframe = document.getElementById('videoIframe') as any;
        if (iframe) {
          youtubePlayer = new (window as any).YT.Player('videoIframe', {
            events: {
              'onReady': onPlayerReady,
              'onStateChange': onPlayerStateChange
            }
          });
        }
      };

      function onPlayerReady(event: any) {
        // Mute by default
        event.target.mute();
      }

      function onPlayerStateChange(event: any) {
        const YT = (window as any).YT;
        if (event.data === YT.PlayerState.PLAYING) {
          isPlaying = true;
          updatePlayPauseIcon();
        } else if (event.data === YT.PlayerState.PAUSED) {
          isPlaying = false;
          updatePlayPauseIcon();
        }
      }
    }

    // Play/Pause Button
    const playPauseBtn = document.getElementById('playPauseBtn');
    const playIcon = document.getElementById('playIcon');
    const pauseIcon = document.getElementById('pauseIcon');

    function updatePlayPauseIcon() {
      if (isPlaying) {
        playIcon?.classList.add('hidden');
        pauseIcon?.classList.remove('hidden');
      } else {
        playIcon?.classList.remove('hidden');
        pauseIcon?.classList.add('hidden');
      }
    }

    playPauseBtn?.addEventListener('click', () => {
      if (videoType === 'youtube' && youtubePlayer) {
        if (isPlaying) {
          youtubePlayer.pauseVideo();
          isPlaying = false;
        } else {
          youtubePlayer.playVideo();
          isPlaying = true;
        }
        updatePlayPauseIcon();
      } else {
        // For Streamable and other videos, we can't control directly
        // Show a message or provide limited functionality
        const iframe = document.getElementById('videoIframe') as any;
        if (iframe) {
          console.log('Play/pause is controlled by the video provider for non-YouTube videos');
        }
      }
    });

    // Mute/Unmute Button
    const muteBtn = document.getElementById('muteBtn');
    const volumeHighIcon = document.getElementById('volumeHighIcon');
    const volumeMuteIcon = document.getElementById('volumeMuteIcon');

    function updateMuteIcon() {
      if (isMuted) {
        volumeHighIcon?.classList.add('hidden');
        volumeMuteIcon?.classList.remove('hidden');
      } else {
        volumeHighIcon?.classList.remove('hidden');
        volumeMuteIcon?.classList.add('hidden');
      }
    }

    muteBtn?.addEventListener('click', () => {
      if (videoType === 'youtube' && youtubePlayer) {
        if (isMuted) {
          youtubePlayer.unMute();
          isMuted = false;
        } else {
          youtubePlayer.mute();
          isMuted = true;
        }
        updateMuteIcon();
      } else {
        // For other video providers, we can't directly control mute via iframe API
        console.log('Mute control is managed by the video provider for non-YouTube videos');
      }
    });

    // Initialize mute icon as muted state
    updateMuteIcon();
  });
</script>
