---
import OIACLayout from "../layouts/oiac-layout.astro";
import Donate from "../components/Donate2.astro";
import Volunteer from "../components/Volunteer2.astro";
import Imams from "../components/Imams.astro";
import Newsletter from "../components/Newsletter2.astro";
import Contact from "../components/Contact.astro";
import Feedback from "../components/Feedback.astro";
import EventsAndPosts from "../components/EventsAndPosts.astro";
// New Fundraiser Success Components
import NewCentreAndCarousel from "../components/NewCentreAndCarousel.astro";
import VideoShowcase from "../components/VideoShowcase.astro";
import PopupPoster from "../components/PopupPoster.astro";
import FeaturedPosters from "../components/FeaturedPosters.astro";
import { getActiveHeroTemplate } from "../lib/db";

// Fetch active hero template (falls back gracefully if none exists)
let activeHeroTemplate = null;
try {
  activeHeroTemplate = await getActiveHeroTemplate();
} catch (error) {
  console.warn('Failed to fetch active hero template:', error);
}
---

<OIACLayout title="Welcome to OIAC">
  <PopupPoster />
  <div class="w-full mx-auto">
    <div class="">
      <!-- Featured Posters (seasonal/time-sensitive) -->
      <FeaturedPosters />

      <!-- New Centre & Carousel -->
      <NewCentreAndCarousel heroTemplate={activeHeroTemplate} />

      <!-- Fundraiser Success Campaign -->
      <VideoShowcase />
      <EventsAndPosts />
      <Donate />
      <Volunteer />
      <Imams />
      <Newsletter />
      <Contact />
      <Feedback />
    </div>
  </div>
</OIACLayout>